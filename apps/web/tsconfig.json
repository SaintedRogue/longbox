{
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"allowSyntheticDefaultImports": true,
		"types": ["vite/client"],
		"jsx": "preserve",
		"module": "es2022",
		"moduleResolution": "Node",
		"composite": true,
		"declaration": true,
		"emitDeclarationOnly": true,
		"outDir": "dist",
		"paths": {
			"@longbox/client": ["../../packages/client/src/index.ts"],
			"@longbox/client/*": ["../../packages/client/src/*"],
			"@longbox/browser": ["../../packages/browser/src/index.ts"],
			"@longbox/browser/*": ["../../packages/browser/src/*"]
		}
	},
	"include": ["src"],
	"references": [
		{
			"path": "../../packages/client"
		},
		{
			"path": "../../packages/browser"
		}
	]
}
